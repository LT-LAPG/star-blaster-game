<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Neon Drift Multiplayer</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body, html { 
            margin: 0; 
            padding: 0; 
            width: 100%; 
            height: 100%; 
            overflow: hidden; 
            background-color: #111; 
            font-family: 'Courier New', Courier, monospace;
            touch-action: none; /* Prevent browser handling of touch gestures like swipe-to-refresh */
        }
        canvas { 
            display: block; 
            width: 100%; 
            height: 100%;
        }
        .ui-layer {
            position: absolute;
            top: 0; left: 0;
            width: 100%; height: 100%;
            pointer-events: none;
            display: flex;
            flex-direction: column;
            justify-content: space-between;
        }
        .pointer-events-auto { pointer-events: auto; }
        
        /* Custom UI Elements */
        .color-btn {
            width: 32px; height: 32px;
            border-radius: 50%;
            cursor: pointer;
            border: 2px solid transparent;
            transition: transform 0.2s, border-color 0.2s;
        }
        .color-btn.selected {
            border-color: white;
            transform: scale(1.2);
            box-shadow: 0 0 10px currentColor;
        }
        .mobile-btn {
            width: 70px; height: 70px;
            background: rgba(255, 255, 255, 0.1);
            border: 2px solid rgba(255, 255, 255, 0.3);
            border-radius: 50%;
            color: white;
            font-weight: bold;
            font-size: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
            user-select: none;
            backdrop-filter: blur(4px);
        }
        .mobile-btn:active, .mobile-btn.active {
            background: rgba(255, 255, 255, 0.3);
            transform: scale(0.95);
        }
        
        /* Grid background pattern */
        .bg-grid {
            background-size: 50px 50px;
            background-image: 
                linear-gradient(to right, rgba(255, 255, 255, 0.05) 1px, transparent 1px),
                linear-gradient(to bottom, rgba(255, 255, 255, 0.05) 1px, transparent 1px);
        }
    </style>
</head>
<body>

    <canvas id="gameCanvas"></canvas>

    <div class="ui-layer">
        
        <!-- Top HUD -->
        <div class="flex justify-between w-full p-4 items-start z-10">
            <div id="hud-speed" class="hidden pointer-events-auto bg-black bg-opacity-70 text-white px-4 py-2 rounded-lg border border-gray-700 shadow-[0_0_15px_rgba(0,150,255,0.3)]">
                <div class="text-3xl font-black text-cyan-400 italic" id="speedValue">0</div>
                <div class="text-xs text-gray-400 uppercase tracking-widest">KM/H</div>
            </div>

            <div id="hud-players" class="hidden pointer-events-auto bg-black bg-opacity-70 text-white p-3 rounded-lg border border-gray-700 shadow-[0_0_15px_rgba(255,0,150,0.3)] min-w-[150px]">
                <h3 class="text-xs text-gray-400 uppercase tracking-widest border-b border-gray-600 pb-1 mb-2">Racers Online</h3>
                <ul id="playerList" class="space-y-1 text-sm font-bold"></ul>
            </div>
        </div>

        <!-- Mobile Controls (Bottom) -->
        <div id="mobile-controls" class="hidden w-full p-6 flex justify-between pointer-events-none pb-12 z-10">
            <div class="flex gap-4 pointer-events-auto">
                <div id="btnLeft" class="mobile-btn">&larr;</div>
                <div id="btnRight" class="mobile-btn">&rarr;</div>
            </div>
            <div class="flex gap-4 pointer-events-auto">
                <div id="btnBrake" class="mobile-btn text-red-400 border-red-500 bg-red-500/10 active:bg-red-500/30">BRK</div>
                <div id="btnGas" class="mobile-btn text-green-400 border-green-500 bg-green-500/10 active:bg-green-500/30">GAS</div>
            </div>
        </div>
    </div>

    <!-- Login Modal -->
    <div id="login-modal" class="absolute inset-0 flex items-center justify-center bg-black bg-grid z-50 pointer-events-auto transition-opacity duration-500">
        <div class="bg-gray-900 p-8 rounded-2xl shadow-[0_0_50px_rgba(0,200,255,0.2)] border border-gray-700 w-[90%] max-w-md text-center">
            <h1 class="text-4xl font-black mb-2 text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-fuchsia-500 italic uppercase tracking-tighter">Neon Drift</h1>
            <p class="text-gray-400 mb-8 text-sm">Real-time Multiplayer Sandbox<br><span class="text-yellow-400 font-bold mt-2 inline-block">Invite friends by sharing the page URL!</span></p>
            
            <div class="mb-6 text-left">
                <label class="block text-xs uppercase tracking-widest text-gray-500 mb-2">Driver Name</label>
                <input type="text" id="playerName" placeholder="Enter your alias" class="w-full px-4 py-3 bg-black border border-gray-600 rounded-lg focus:outline-none focus:border-cyan-500 text-white font-bold transition-colors" maxlength="12" value="Racer">
            </div>

            <div class="mb-8 text-left">
                <label class="block text-xs uppercase tracking-widest text-gray-500 mb-2">Paint Job</label>
                <div class="flex justify-between" id="colorPicker">
                    <!-- Colors JS injected -->
                </div>
            </div>

            <button id="joinBtn" disabled class="w-full py-4 bg-gray-700 text-gray-400 rounded-lg font-black uppercase tracking-widest transition-all duration-300">
                Connecting...
            </button>
            <p id="errorMsg" class="text-red-400 text-sm mt-4 hidden"></p>
        </div>
    </div>

    <!-- Firebase Logic & Game Engine -->
    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-app.js";
        import { getAuth, signInAnonymously, signInWithCustomToken, onAuthStateChanged } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-auth.js";
        import { getFirestore, collection, doc, setDoc, onSnapshot, deleteDoc } from "https://www.gstatic.com/firebasejs/11.6.1/firebase-firestore.js";

        // --- Configuration & Initialization ---
        const firebaseConfig = typeof __firebase_config !== 'undefined' ? JSON.parse(__firebase_config) : null;
        const appId = typeof __app_id !== 'undefined' ? __app_id : 'default-neon-drift';
        
        let app, auth, db;
        let currentUser = null;
        let gameActive = false;

        // UI Elements
        const loginModal = document.getElementById('login-modal');
        const joinBtn = document.getElementById('joinBtn');
        const playerNameInput = document.getElementById('playerName');
        const colorPicker = document.getElementById('colorPicker');
        const errorMsg = document.getElementById('errorMsg');
        const hudSpeed = document.getElementById('hud-speed');
        const hudPlayers = document.getElementById('hud-players');
        const speedValue = document.getElementById('speedValue');
        const playerList = document.getElementById('playerList');
        const mobileControls = document.getElementById('mobile-controls');
        const canvas = document.getElementById('gameCanvas');
        const ctx = canvas.getContext('2d');

        // Available Colors
        const colors = [
            { id: 'cyan', hex: '#00ffff' },
            { id: 'fuchsia', hex: '#ff00ff' },
            { id: 'yellow', hex: '#ffff00' },
            { id: 'green', hex: '#00ff00' },
            { id: 'red', hex: '#ff3333' },
            { id: 'orange', hex: '#ff9900' }
        ];
        let selectedColor = colors[0].hex;

        // Populate Colors
        colors.forEach((c, index) => {
            const btn = document.createElement('div');
            btn.className = `color-btn ${index === 0 ? 'selected' : ''}`;
            btn.style.backgroundColor = c.hex;
            btn.style.color = c.hex; // for box-shadow
            btn.onclick = () => {
                document.querySelectorAll('.color-btn').forEach(b => b.classList.remove('selected'));
                btn.classList.add('selected');
                selectedColor = c.hex;
            };
            colorPicker.appendChild(btn);
        });

        // --- Firebase Setup ---
        if (!firebaseConfig) {
            showError("Firebase configuration missing. Cannot connect to multiplayer server.");
        } else {
            try {
                app = initializeApp(firebaseConfig);
                auth = getAuth(app);
                db = getFirestore(app);
                initAuth();
            } catch (e) {
                showError("Error initializing systems: " + e.message);
            }
        }

        async function initAuth() {
            try {
                if (typeof __initial_auth_token !== 'undefined' && __initial_auth_token) {
                    await signInWithCustomToken(auth, __initial_auth_token);
                } else {
                    await signInAnonymously(auth);
                }
            } catch (e) {
                showError("Authentication failed: " + e.message);
            }
        }

        onAuthStateChanged(auth, (user) => {
            currentUser = user;
            if (user) {
                joinBtn.disabled = false;
                joinBtn.textContent = "Start Engine";
                joinBtn.className = "w-full py-4 bg-gradient-to-r from-cyan-500 to-blue-600 hover:from-cyan-400 hover:to-blue-500 text-white rounded-lg font-black uppercase tracking-widest shadow-[0_0_20px_rgba(0,255,255,0.4)] transition-all duration-300 transform hover:scale-105";
            }
        });

        function showError(msg) {
            errorMsg.textContent = msg;
            errorMsg.classList.remove('hidden');
        }

        // --- Game Logic ---
        
        // Input State
        const keys = { w: false, a: false, s: false, d: false, ArrowUp: false, ArrowDown: false, ArrowLeft: false, ArrowRight: false };
        
        // Physics & Player State
        const myCar = {
            x: 0, y: 0,
            angle: -Math.PI / 2, // Facing up
            speed: 0,
            maxSpeed: 20,
            acceleration: 0.5,
            friction: 0.96,
            turnSpeed: 0.06,
            width: 24, height: 44,
            name: "",
            color: selectedColor,
            boost: 0 // New boost property
        };

        const powerUps = [
            { x: 0, y: -1500, active: true, respawnAt: 0 },
            { x: 1500, y: -1100, active: true, respawnAt: 0 },
            { x: 3000, y: 0, active: true, respawnAt: 0 },
            { x: 1500, y: 1100, active: true, respawnAt: 0 },
            { x: 0, y: 1500, active: true, respawnAt: 0 },
            { x: -1500, y: 1100, active: true, respawnAt: 0 },
            { x: -3000, y: 0, active: true, respawnAt: 0 },
            { x: -1500, y: -1100, active: true, respawnAt: 0 }
        ];

        const remotePlayers = {};
        let syncInterval;
        let unsubscribeSnapshot = null;

        // Resize Handling
        function resize() {
            canvas.width = window.innerWidth;
            canvas.height = window.innerHeight;
        }
        window.addEventListener('resize', resize);
        resize();

        // Keyboard Event Listeners
        window.addEventListener('keydown', (e) => { if (keys.hasOwnProperty(e.key)) keys[e.key] = true; });
        window.addEventListener('keyup', (e) => { if (keys.hasOwnProperty(e.key)) keys[e.key] = false; });

        // Touch Setup for Mobile UI
        if ('maxTouchPoints' in navigator && navigator.maxTouchPoints > 0) {
            mobileControls.classList.remove('hidden');
            
            const bindTouch = (id, key) => {
                const el = document.getElementById(id);
                el.addEventListener('touchstart', (e) => { e.preventDefault(); keys[key] = true; el.classList.add('active'); });
                el.addEventListener('touchend', (e) => { e.preventDefault(); keys[key] = false; el.classList.remove('active'); });
                el.addEventListener('touchcancel', (e) => { e.preventDefault(); keys[key] = false; el.classList.remove('active'); });
            };

            bindTouch('btnLeft', 'ArrowLeft');
            bindTouch('btnRight', 'ArrowRight');
            bindTouch('btnGas', 'ArrowUp');
            bindTouch('btnBrake', 'ArrowDown');
        }

        // Start Game Flow
        joinBtn.addEventListener('click', () => {
            if (!currentUser) return;
            
            myCar.name = playerNameInput.value.trim() || "Racer";
            myCar.color = selectedColor;
            
            // Random start position near center
            myCar.x = (Math.random() - 0.5) * 500;
            myCar.y = (Math.random() - 0.5) * 500;
            
            loginModal.style.opacity = '0';
            setTimeout(() => {
                loginModal.style.display = 'none';
                hudSpeed.classList.remove('hidden');
                hudPlayers.classList.remove('hidden');
                gameActive = true;
                startMultiplayer();
                requestAnimationFrame(gameLoop);
            }, 500);
        });

        // --- Multiplayer Sync ---
        function startMultiplayer() {
            const playersCol = collection(db, 'artifacts', appId, 'public', 'data', 'players');
            
            // 1. Listen to others
            unsubscribeSnapshot = onSnapshot(playersCol, (snapshot) => {
                snapshot.docs.forEach(docSnap => {
                    if (docSnap.id === currentUser.uid) return; // Skip self
                    
                    const data = docSnap.data();
                    if (!remotePlayers[docSnap.id]) {
                        remotePlayers[docSnap.id] = { render: { ...data }, target: data };
                    } else {
                        remotePlayers[docSnap.id].target = data;
                    }
                });
                updateLeaderboard();
            }, (error) => {
                console.error("Firestore sync error:", error);
            });

            // 2. Broadcast self (Throttled to ~10 times per second)
            syncInterval = setInterval(() => {
                if (!currentUser || !gameActive) return;
                const playerRef = doc(db, 'artifacts', appId, 'public', 'data', 'players', currentUser.uid);
                
                // Only sync if moving or periodically to keep alive
                setDoc(playerRef, {
                    x: Math.round(myCar.x),
                    y: Math.round(myCar.y),
                    angle: Number(myCar.angle.toFixed(3)),
                    color: myCar.color,
                    name: myCar.name,
                    timestamp: Date.now()
                }).catch(e => console.error("Write error:", e));
                
            }, 100);
        }

        // Cleanup on exit
        window.addEventListener('beforeunload', () => {
            if (currentUser && gameActive) {
                const playerRef = doc(db, 'artifacts', appId, 'public', 'data', 'players', currentUser.uid);
                // Fire and forget delete
                navigator.sendBeacon(`https://firestore.googleapis.com/v1/projects/${firebaseConfig.projectId}/databases/(default)/documents/artifacts/${appId}/public/data/players/${currentUser.uid}?currentDocument.exists=true`, null);
            }
        });

        function updateLeaderboard() {
            let html = `<li class="text-cyan-400 flex items-center gap-2">
                <span class="w-3 h-3 rounded-full inline-block shadow-[0_0_5px_currentColor]" style="background-color: ${myCar.color}"></span>
                ${myCar.name} (You)
            </li>`;
            
            const now = Date.now();
            let activeCount = 1;

            for (let id in remotePlayers) {
                const p = remotePlayers[id].target;
                // Remove stale players (> 5 seconds no update)
                if (now - p.timestamp > 5000) {
                    delete remotePlayers[id];
                    continue;
                }
                html += `<li class="text-gray-300 flex items-center gap-2">
                    <span class="w-3 h-3 rounded-full inline-block shadow-[0_0_5px_currentColor]" style="background-color: ${p.color}"></span>
                    ${p.name}
                </li>`;
                activeCount++;
            }
            playerList.innerHTML = html;
        }

        // --- Render & Physics Loop ---
        const trails = []; // Store light trails
        let camX = 0;
        let camY = 0;
        let zoom = 1.0;

        function updatePhysics() {
            // Power Up Logic
            const now = Date.now();
            if (myCar.boost > 0) {
                myCar.boost--;
                myCar.maxSpeed = 35; // Boosted Top Speed
                myCar.acceleration = 1.2;
            } else {
                myCar.maxSpeed = 20; // Normal Top Speed
                myCar.acceleration = 0.5;
            }

            powerUps.forEach(p => {
                if (!p.active && now > p.respawnAt) p.active = true;
                if (p.active) {
                    const dist = Math.hypot(myCar.x - p.x, myCar.y - p.y);
                    if (dist < 50) {
                        p.active = false;
                        p.respawnAt = now + 5000; // 5 second respawn
                        myCar.boost = 120; // 120 frames of boost (~2 seconds)
                    }
                }
            });

            // Acceleration
            let moving = false;
            if (keys.w || keys.ArrowUp) { myCar.speed += myCar.acceleration; moving = true; }
            if (keys.s || keys.ArrowDown) { myCar.speed -= myCar.acceleration; moving = true; }
            
            // Steering (only if moving)
            if (Math.abs(myCar.speed) > 0.5) {
                const turnMultiplier = (myCar.speed > 0 ? 1 : -1) * (Math.abs(myCar.speed) / myCar.maxSpeed + 0.2); // Better handling curve
                if (keys.a || keys.ArrowLeft) myCar.angle -= myCar.turnSpeed * turnMultiplier;
                if (keys.d || keys.ArrowRight) myCar.angle += myCar.turnSpeed * turnMultiplier;
            }

            // Apply friction & limits
            if (!moving) myCar.speed *= myCar.friction; 
            myCar.speed = Math.max(Math.min(myCar.speed, myCar.maxSpeed), -myCar.maxSpeed / 2);

            // Stop completely if very slow
            if (Math.abs(myCar.speed) < 0.1) myCar.speed = 0;

            // Apply velocity
            myCar.x += Math.cos(myCar.angle) * myCar.speed;
            myCar.y += Math.sin(myCar.angle) * myCar.speed;

            // Update UI
            speedValue.innerText = Math.round(Math.abs(myCar.speed) * 10);
        }

        function interpolateRemotePlayers() {
            const lerp = (start, end, amt) => (1 - amt) * start + amt * end;
            const now = Date.now();

            for (let id in remotePlayers) {
                let rp = remotePlayers[id];
                
                // Cleanup inline to be safe
                if (now - rp.target.timestamp > 5000) {
                    delete remotePlayers[id];
                    continue;
                }

                // Smoothly interpolate rendering position towards target position
                rp.render.x = lerp(rp.render.x, rp.target.x, 0.3);
                rp.render.y = lerp(rp.render.y, rp.target.y, 0.3);
                
                // Angle interpolation (Handling wrap-around is tricky, snapping is acceptable for fast updates, but let's do simple lerp)
                // To prevent spinning, we just snap the angle for simplicity in this prototype.
                rp.render.angle = rp.target.angle;
            }
        }

        // -- Drawing Functions --
        function drawTrack() {
            const S = 3000; // Increased track scale
            const C = 2000; // Curve steepness
            
            // Draw a massive "Figure 8 / Peanut" track in the world
            ctx.strokeStyle = '#222'; // Asphalt
            ctx.lineWidth = 600; // Wider track
            ctx.lineJoin = 'round';
            ctx.lineCap = 'round';
            
            ctx.beginPath();
            ctx.moveTo(-S, 0);
            ctx.bezierCurveTo(-S, -C, S, -C, S, 0);
            ctx.bezierCurveTo(S, C, -S, C, -S, 0);
            ctx.stroke();

            // Track Borders
            ctx.strokeStyle = '#ff0055'; // Neon border
            ctx.lineWidth = 15;
            ctx.shadowBlur = 20;
            ctx.shadowColor = '#ff0055';
            ctx.stroke();
            ctx.shadowBlur = 0; // reset

            // Center Dash
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.5)';
            ctx.lineWidth = 8;
            ctx.setLineDash([80, 80]);
            ctx.beginPath();
            ctx.moveTo(-S, 0);
            ctx.bezierCurveTo(-S, -C, S, -C, S, 0);
            ctx.bezierCurveTo(S, C, -S, C, -S, 0);
            ctx.stroke();
            ctx.setLineDash([]);
        }

        function drawPowerUps() {
            const time = Date.now() / 200;
            powerUps.forEach(p => {
                if (p.active) {
                    ctx.save();
                    ctx.translate(p.x, p.y);
                    ctx.rotate(time); // Spin animation
                    ctx.shadowBlur = 20;
                    ctx.shadowColor = '#ffff00';
                    ctx.strokeStyle = '#ffff00';
                    ctx.lineWidth = 4;
                    ctx.strokeRect(-15, -15, 30, 30);
                    ctx.fillStyle = 'rgba(255, 255, 0, 0.4)';
                    ctx.fillRect(-15, -15, 30, 30);
                    
                    // Inner core
                    ctx.rotate(-time * 2);
                    ctx.fillStyle = '#fff';
                    ctx.fillRect(-5, -5, 10, 10);
                    ctx.restore();
                }
            });
        }

        function drawGrid(camX, camY) {
            const gridSize = 200;
            // Pad the grid bounds to account for the dynamic zoom out
            const startX = Math.floor(camX / gridSize) * gridSize - gridSize * 2;
            const startY = Math.floor(camY / gridSize) * gridSize - gridSize * 2;
            
            ctx.strokeStyle = 'rgba(255, 255, 255, 0.05)';
            ctx.lineWidth = 2;
            
            ctx.beginPath();
            for(let x = startX; x < camX + canvas.width * 1.5 + gridSize; x += gridSize) {
                ctx.moveTo(x, camY - canvas.height * 0.5); ctx.lineTo(x, camY + canvas.height * 1.5);
            }
            for(let y = startY; y < camY + canvas.height * 1.5 + gridSize; y += gridSize) {
                ctx.moveTo(camX - canvas.width * 0.5, y); ctx.lineTo(camX + canvas.width * 1.5, y);
            }
            ctx.stroke();
        }

        function drawCar(carObj, isLocal) {
            ctx.save();
            ctx.translate(carObj.x, carObj.y);
            ctx.rotate(carObj.angle + Math.PI / 2); // Fix alignment to match math

            // Car Shadow
            ctx.fillStyle = 'rgba(0,0,0,0.5)';
            ctx.fillRect(-carObj.width/2 + 5, -carObj.height/2 + 5, carObj.width, carObj.height);

            // Tires
            ctx.fillStyle = '#000';
            ctx.fillRect(-carObj.width/2 - 2, -carObj.height/2 + 5, 4, 10);
            ctx.fillRect(carObj.width/2 - 2, -carObj.height/2 + 5, 4, 10);
            ctx.fillRect(-carObj.width/2 - 2, carObj.height/2 - 15, 4, 10);
            ctx.fillRect(carObj.width/2 - 2, carObj.height/2 - 15, 4, 10);

            // Chassis
            ctx.fillStyle = carObj.color || '#fff';
            ctx.shadowBlur = 15;
            ctx.shadowColor = carObj.color;
            // Round rect representation
            ctx.beginPath();
            ctx.roundRect(-carObj.width/2, -carObj.height/2, carObj.width, carObj.height, 5);
            ctx.fill();
            ctx.shadowBlur = 0;

            // Windshield
            ctx.fillStyle = '#111';
            ctx.beginPath();
            ctx.roundRect(-carObj.width/2 + 2, -carObj.height/4, carObj.width - 4, carObj.height/3, 3);
            ctx.fill();

            // Headlights
            ctx.fillStyle = '#fff';
            ctx.shadowBlur = 10;
            ctx.shadowColor = '#fff';
            ctx.fillRect(carObj.width/2 - 6, -carObj.height/2 + 2, 4, 6);
            ctx.fillRect(-carObj.width/2 + 2, -carObj.height/2 + 2, 4, 6);
            
            // Light beams (if moving forward or local)
            if (isLocal || Math.abs(carObj.speed) > 1) {
                ctx.fillStyle = 'rgba(255, 255, 255, 0.15)';
                ctx.beginPath();
                ctx.moveTo(carObj.width/2 - 4, -carObj.height/2);
                ctx.lineTo(carObj.width/2 + 40, -carObj.height/2 - 150);
                ctx.lineTo(carObj.width/2 - 40, -carObj.height/2 - 150);
                ctx.fill();
                
                ctx.beginPath();
                ctx.moveTo(-carObj.width/2 + 4, -carObj.height/2);
                ctx.lineTo(-carObj.width/2 + 40, -carObj.height/2 - 150);
                ctx.lineTo(-carObj.width/2 - 40, -carObj.height/2 - 150);
                ctx.fill();
            }
            ctx.shadowBlur = 0;

            // Nameplate
            ctx.rotate(-(carObj.angle + Math.PI / 2)); // Keep text upright
            ctx.fillStyle = '#fff';
            ctx.font = 'bold 12px monospace';
            ctx.textAlign = 'center';
            ctx.fillText(carObj.name || "Racer", 0, -carObj.height/2 - 20);

            ctx.restore();
        }

        // Main Loop
        function gameLoop() {
            if (!gameActive) return;

            updatePhysics();
            interpolateRemotePlayers();

            // Add trails for local car
            if (Math.abs(myCar.speed) > 2) {
                trails.push({ x: myCar.x, y: myCar.y, angle: myCar.angle, color: myCar.color, alpha: 1.0 });
            }
            // Add trails for remote cars
            for (let id in remotePlayers) {
                let rp = remotePlayers[id].render;
                if (Math.abs(rp.x - remotePlayers[id].target.x) > 0.1 || Math.abs(rp.y - remotePlayers[id].target.y) > 0.1) {
                    trails.push({ x: rp.x, y: rp.y, angle: rp.angle, color: rp.color, alpha: 1.0 });
                }
            }

            // Clear Screen
            ctx.fillStyle = '#111';
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // Smooth Camera & Dynamic Zoom
            const targetCamX = myCar.x - canvas.width / 2;
            const targetCamY = myCar.y - canvas.height / 2;
            camX += (targetCamX - camX) * 0.1; // Smooth follow
            camY += (targetCamY - camY) * 0.1;

            ctx.save();
            
            // Calculate zoom based on speed ratio
            const targetZoom = 1.0 - (Math.abs(myCar.speed) / myCar.maxSpeed) * 0.25;
            zoom += (targetZoom - zoom) * 0.05;
            
            // Apply Zoom from screen center
            ctx.translate(canvas.width / 2, canvas.height / 2);
            ctx.scale(zoom, zoom);
            ctx.translate(-canvas.width / 2, -canvas.height / 2);

            ctx.translate(-camX, -camY); // Apply Camera

            drawGrid(camX, camY);
            drawTrack();
            drawPowerUps(); // Draw the speed boosts

            // Draw Trails
            ctx.lineWidth = 6;
            ctx.lineCap = 'round';
            for (let i = trails.length - 1; i >= 0; i--) {
                let t = trails[i];
                t.alpha -= 0.05; // Fade out speed
                if (t.alpha <= 0) {
                    trails.splice(i, 1);
                    continue;
                }
                ctx.strokeStyle = t.color;
                ctx.globalAlpha = t.alpha * 0.4;
                ctx.beginPath();
                ctx.moveTo(t.x, t.y);
                ctx.lineTo(t.x - Math.cos(t.angle)*15, t.y - Math.sin(t.angle)*15); 
                ctx.stroke();
            }
            ctx.globalAlpha = 1.0;

            // Draw Remote Players
            for (let id in remotePlayers) {
                drawCar({
                    x: remotePlayers[id].render.x,
                    y: remotePlayers[id].render.y,
                    angle: remotePlayers[id].render.angle,
                    color: remotePlayers[id].render.color,
                    name: remotePlayers[id].render.name,
                    width: myCar.width,
                    height: myCar.height
                }, false);
            }

            // Draw Local Player
            drawCar(myCar, true);

            ctx.restore(); // Remove Camera

            requestAnimationFrame(gameLoop);
        }

    </script>
</body>
</html>
